{
  "name": "exam-platform-backend",
  "version": "1.0.0",
  "description": "Exam Preparation Platform - Backend API",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage",
    "test:api": "newman run postman/exam-platform.postman_collection.json --env-var base_url=http://127.0.0.1:3000 --reporters cli,json --reporter-json-export postman/newman-report.json"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "globalSetup": "<rootDir>/src/__tests__/jestGlobalSetup.ts",
    "testMatch": ["**/__tests__/**/*.test.ts"],
    "testTimeout": 30000,
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", { "diagnostics": false }]
    },
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/server.ts",
      "!src/**/*.d.ts",
      "!src/__tests__/**",
      "!src/seed/**"
    ],
    "coverageProvider": "v8",
    "coverageReporters": ["text", "lcov", "html"],
    "coverageDirectory": "coverage",
    "coverageThreshold": {
      "global": {
        "statements": 80,
        "branches": 70,
        "functions": 80,
        "lines": 80
      }
    },
    "forceExit": true,
    "verbose": true
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.8.0"
  },
  "mongodbMemoryServer": {
    "version": "7.0.14"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "newman": "^6.2.1",
    "mongodb-memory-server": "^11.0.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}